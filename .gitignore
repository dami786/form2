# ═══════════════════════════════════════════════════════════
# JerseyBird form – PUSH ONLY FROM THIS FOLDER
# Path: OneDrive\Desktop\form
# GitHub should show ~70 files, NOT 10,000
# ═══════════════════════════════════════════════════════════

# ─── Node.js (most common cause of 10k+ files) ───
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm/
.yarn/
.pnp.*
.next/
dist/
build/
out/
.nuxt/
.cache/
.parcel-cache/
coverage/
.nyc_output/

# ─── Large reference downloads (not needed on GitHub) ───
ref/
ref-*.html
ref-col-*.html
ref-product-*.html
ref-pf-*.html
ref-paperform-*.html
_pf_page.html
pf-embed.min.js
pf-api.json

# ─── Editor / IDE / OS ───
.cursor/
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db
desktop.ini

# ─── Python ───
__pycache__/
*.py[cod]
*.pyo
.Python
.venv/
venv/
env/

# ─── Logs & temp ───
*.log
*.tmp
*.temp

# ─── Secrets (never commit) ───
.env
.env.*
*.pem
credentials.json
*.key
